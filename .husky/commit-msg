#!/bin/sh

# Conventional Commits validation
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "📝 Validating commit message..."

# Check if commit message is empty
if [ -z "$COMMIT_MSG" ]; then
  echo "${RED}❌ Commit message is empty${NC}"
  exit 1
fi

# Conventional Commits format check
# Format: <type>(<scope>): <subject>
# or: <type>: <subject>
PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .+"

if echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo "${GREEN}✅ Commit message follows Conventional Commits format${NC}"
  
  # Extract type
  TYPE=$(echo "$COMMIT_MSG" | sed -E 's/^([a-z]+)(\(.+\))?: .+/\1/')
  
  # Print type
  echo "   Type: $TYPE"
  
  # Check if it's a breaking change
  if echo "$COMMIT_MSG" | grep -qE "^[a-z]+(\(.+\))?!: "; then
    echo "${YELLOW}⚠️  This is a BREAKING CHANGE commit${NC}"
  fi
  
  exit 0
else
  echo "${RED}❌ Commit message does not follow Conventional Commits format${NC}"
  echo ""
  echo "Expected format:"
  echo "  <type>(<scope>): <subject>"
  echo ""
  echo "Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo "Example: feat(frontend): add user authentication"
  echo "Example: fix(core): resolve workflow validation bug"
  exit 1
fi
