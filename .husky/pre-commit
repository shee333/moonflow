#!/bin/sh

echo "🔍 Running pre-commit checks..."

# Get the root directory
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track errors
ERRORS=0

# Check frontend files
check_frontend() {
  echo ""
  echo "📦 Checking frontend..."
  
  if [ -d "frontend" ]; then
    cd frontend || exit 1
    
    # Run lint
    echo "Running ESLint..."
    npm run lint 2>/dev/null
    if [ $? -ne 0 ]; then
      echo "${RED}❌ ESLint failed${NC}"
      ERRORS=$((ERRORS + 1))
    else
      echo "${GREEN}✅ ESLint passed${NC}"
    fi
    
    # Run typecheck
    echo "Running TypeScript check..."
    npm run typecheck 2>/dev/null
    if [ $? -ne 0 ]; then
      echo "${RED}❌ TypeScript check failed${NC}"
      ERRORS=$((ERRORS + 1))
    else
      echo "${GREEN}✅ TypeScript check passed${NC}"
    fi
    
    cd "$REPO_ROOT" || exit 1
  fi
}

# Check core files
check_core() {
  echo ""
  echo "🌙 Checking MoonBit core..."
  
  if [ -d "core" ]; then
    cd core || exit 1
    
    # Run Moon check
    echo "Running Moon check..."
    moon check 2>/dev/null
    if [ $? -ne 0 ]; then
      echo "${RED}❌ Moon check failed${NC}"
      ERRORS=$((ERRORS + 1))
    else
      echo "${GREEN}✅ Moon check passed${NC}"
    fi
    
    # Run Moon fmt check
    echo "Checking MoonBit format..."
    moon fmt --check 2>/dev/null
    if [ $? -ne 0 ]; then
      echo "${RED}❌ MoonBit format issues found${NC}"
      echo "${YELLOW}💡 Run 'moon fmt' to fix formatting${NC}"
      ERRORS=$((ERRORS + 1))
    else
      echo "${GREEN}✅ MoonBit format OK${NC}"
    fi
    
    cd "$REPO_ROOT" || exit 1
  fi
}

# Run checks
check_frontend
check_core

# Summary
echo ""
echo "========================================"
if [ $ERRORS -eq 0 ]; then
  echo "${GREEN}✅ All pre-commit checks passed!${NC}"
  echo "========================================"
  exit 0
else
  echo "${RED}❌ Pre-commit checks failed with $ERRORS error(s)${NC}"
  echo "${YELLOW}💡 Please fix the issues above before committing${NC}"
  echo "========================================"
  exit 1
fi
